CONTAINS(PRIORVALUE({!$Record.Contact.Membership_Years__c}), TEXT(YEAR({!$Record.Contact.Last_Membership_Date_v2__c}))), 
{!$Record.Contact.Membership_Years__c},
IF(ISBLANK({!$Record.Contact.Membership_Years__c}),
TEXT(YEAR({!$Record.Contact.Last_Membership_Date_v2__c})),
PRIORVALUE({!$Record.Contact.Membership_Years__c}) + &quot;, &quot; + TEXT(YEAR({!$Record.Contact.Last_Membership_Date_v2__c}))
)
)</expression>
    </formulas>
