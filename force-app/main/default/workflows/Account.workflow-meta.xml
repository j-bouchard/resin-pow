    <rules>
        <fullName>Account Partner%2FOrg Stage - Current</fullName>
        <actions>
            <name>account_foundation_stage_current</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <booleanFilter>(1 OR 3) AND 2</booleanFilter>
        <criteriaItems>
            <field>Account.RecordTypeId</field>
            <operation>equals</operation>
            <value>Organization</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.npo02__OppAmountLastNDays__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.RecordTypeId</field>
            <operation>equals</operation>
            <value>Partner</value>
        </criteriaItems>
        <description>When an organization has donated within the last 365 days, they will be marked as current</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
