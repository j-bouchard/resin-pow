    <formulas>
        <name>entry_points_p2a</name>
        <dataType>String</dataType>
        <expression>IF(
CONTAINS(PRIORVALUE({!$Record.Contact.member_entry_points__c}), {!$Record.membership_campaign_member_type__c}), 
{!$Record.Contact.member_entry_points__c},
IF(
ISBLANK({!$Record.Contact.member_entry_points__c}), 
{!$Record.membership_campaign_member_type__c},
{!$Record.Contact.member_entry_points__c} + &quot;, &quot; + {!$Record.membership_campaign_member_type__c}
)
)</expression>
    </formulas>
    <formulas>
        <name>membership_years_p2a</name>
