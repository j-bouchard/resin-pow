{
  "permissions": {
    "allow": [
      "Bash(sf org *)",
      "Bash(sf project *)",
      "Bash(sf apex run test*)",
      "Bash(sf apex get*)",
      "Bash(sf data query *)",
      "Bash(sf data get *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(jq *)",
      "Bash(diff *)",
      "Bash(.claude/scripts/audit.sh *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(sf data delete *)",
      "Bash(sf data update *)",
      "Bash(sf data upsert *)",
      "Bash(sf data create *)",
      "Bash(sf data import *)",
      "Bash(sf data tree *)",
      "Bash(sf data bulk *)",
      "Bash(sf apex run script*)",
      "Bash(sf apex run --file*)",
      "Bash(sf apex run -f *)",
      "Bash(git push *--force*)",
      "Bash(git push *-f *)",
      "Bash(git push*origin main*)",
      "Bash(git reset --hard*)",
      "Bash(git branch -D*)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start-sf-auth.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-sf-data-changes.sh"
          }
        ]
      }
    ]
  }
}
