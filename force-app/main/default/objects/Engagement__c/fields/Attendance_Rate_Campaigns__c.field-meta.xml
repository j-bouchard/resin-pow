<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Attendance_Rate_Campaigns__c</fullName>
    <formula>IF((Attended_Campaign__c + Invited_Campaign__c) &gt; 0, Attended_Campaign__c /(Attended_Campaign__c + Invited_Campaign__c), NULL)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Attendance Rate - Campaigns</label>
    <precision>18</precision>
    <required>false</required>
    <scale>2</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
