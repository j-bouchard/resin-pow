    <rules>
        <fullName>Account Foundation Stage - Lapsed</fullName>
        <active>true</active>
        <description>When a organization account hasn&apos;t donated in greater than 365 days but less than 730 days, this workflow changes the account stage to Lapsed</description>
        <formula>AND((npo02__LastCloseDate__c &gt; (TODAY() - 365)) &amp;&amp;(npo02__LastCloseDate__c) &lt; (TODAY() - 730)) &amp;&amp; (RecordType.Id)  = &quot;0124P0000014gPPQAY&quot;</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <actions>
                <name>Account_Foundation_Stage_Lapsed</name>
                <type>FieldUpdate</type>
            </actions>
            <offsetFromField>Account.npo02__LastCloseDate__c</offsetFromField>
            <timeLength>366</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
    </rules>
    <rules>
        <fullName>Account Foundation Stage - Lost</fullName>
        <active>true</active>
        <description>A foundation account&apos;s stage will change to lost after not donating for over 730 days</description>
        <formula>AND (npo02__LastCloseDate__c &gt; (TODAY() - 730)) &amp;&amp; ( RecordType.Id  = &quot;0124P0000014gPPQAY&quot;)</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <actions>
                <name>Account_Foundation_Stage_Lost</name>
                <type>FieldUpdate</type>
            </actions>
            <offsetFromField>Account.npo02__LastCloseDate__c</offsetFromField>
            <timeLength>731</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
    </rules>
    <rules>
        <fullName>Account Partner Stage - Current</fullName>
        <active>false</active>
        <criteriaItems>
            <field>Account.RecordTypeId</field>
            <operation>equals</operation>
            <value>Partner</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.npo02__OppAmountLastNDays__c</field>
            <operation>greaterThan</operation>
            <value>0</value>
        </criteriaItems>
        <description>When an organization has donated within the last 365 days, they will be marked as current</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
