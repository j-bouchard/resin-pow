<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>Campaign_to_Inactive</fullName>
        <description>Sets campaign to inactive</description>
        <field>IsActive</field>
        <literalValue>0</literalValue>
        <name>Campaign to Inactive</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Drop Hosts 2021</fullName>
        <active>false</active>
        <criteriaItems>
            <field>Campaign.Type_of_Event__c</field>
            <operation>equals</operation>
            <value>Drop</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Inactive Campaign After End Date</fullName>
        <active>false</active>
        <criteriaItems>
            <field>Campaign.Name</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <actions>
                <name>Campaign_to_Inactive</name>
                <type>FieldUpdate</type>
            </actions>
            <offsetFromField>Campaign.EndDate</offsetFromField>
            <timeLength>1</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
    </rules>
    <rules>
        <fullName>Sample</fullName>
        <active>false</active>
        <criteriaItems>
            <field>Campaign.Name</field>
            <operation>contains</operation>
            <value>Pledge to Vote</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Volunteers Needed</fullName>
        <actions>
            <name>Volunteers_Needed</name>
            <type>Task</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Campaign.Volunteers_Needed__c</field>
            <operation>equals</operation>
            <value>Yes</value>
        </criteriaItems>
        <description>When the &quot;Volunteers Needed?&quot; field is selected as yes, assign Lindsey a task of finding volunteers.</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <tasks>
        <fullName>Volunteers_Needed</fullName>
        <assignedTo>lindsey@protectourwinters.org</assignedTo>
        <assignedToType>user</assignedToType>
        <dueDateOffset>-7</dueDateOffset>
        <notifyAssignee>false</notifyAssignee>
        <offsetFromField>Campaign.Event_Start_Date_and_Time__c</offsetFromField>
        <priority>Normal</priority>
        <protected>false</protected>
        <status>Not Started</status>
        <subject>Volunteers Needed</subject>
    </tasks>
</Workflow>
