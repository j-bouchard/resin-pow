    <!-- ============================================================ -->
    <!-- SECURITY, PROFILES & PERMISSIONS                            -->
    <!-- ============================================================ -->
    <!--
      Profile is intentionally NOT wildcarded.
      A `*` on Profile pulls every standard profile with full permission
      payloads; any admin-driven change in prod then collides with deploys
      from this repo. All permission management goes through PermissionSet
      and PermissionSetGroup. If a specific profile MUST be tracked, add
      it explicitly by name here and remove the matching line from
      `.forceignore`.
    -->
    <types>
        <members>*</members>
        <name>PermissionSet</name>
    </types>
    <types>
        <members>*</members>
        <name>PermissionSetGroup</name>
    </types>
    <types>
        <members>*</members>
        <name>Role</name>
    </types>
    <types>
        <members>*</members>
        <name>Group</name>
    </types>
