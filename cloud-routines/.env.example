# Cloud routine environment variables — copy values from the External Client
# App "Consumer Key" and "Consumer Secret" fields in each POW org. These are
# stored in the routine config at claude.ai/code/routines, NOT committed.

# --- POW Sandbox ---
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_INSTANCE_URL=https://resourcemedia--pow.sandbox.my.salesforce.com

# --- POW Production ---
SF_PROD_CLIENT_ID=
SF_PROD_CLIENT_SECRET=
SF_PROD_INSTANCE_URL=https://pow.my.salesforce.com

# --- ClickUp ---
# Personal API token: https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=
CLICKUP_POW_LIST_ID=

# --- Slack ---
# Incoming webhook for #resin-pipeline
SLACK_WEBHOOK_URL=

# --- GitHub ---
# Fine-grained PAT scoped to j-bouchard/resin-pow with contents:write + pull_requests:write
GITHUB_TOKEN=
